name: Nx Continuous Deployment

on:
  workflow_run:
    workflows: ["Nx Continuous Integration"]   # must match CI workflow name
    types: [completed]

  workflow_dispatch:   # manual trigger

jobs:
  cd:
    name: Continuous Deployment
    runs-on: ubuntu-latest
    # Only run automatically if CI finished successfully
    if: ${{ github.event.workflow_run.conclusion == 'success' || github.event_name == 'workflow_dispatch' }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install dependencies
        run: npm ci

      - name: Set Docker Tag
        run: |
          TAG=${GITHUB_RUN_NUMBER}-${GITHUB_SHA::7}
          echo "TAG=$TAG" >> $GITHUB_ENV

      - name: Docker Login
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKERHUB_USERNAME }}
          password: ${{ secrets.DOCKERHUB_TOKEN }}

      - name: Build Docker images (affected only)
        run: |
          npx nx affected \
            --target=docker-build \
            --base=origin/main

      - name: Push Docker images (affected only)
        run: |
          npx nx affected \
            --target=docker-push \
            --base=origin/main
