# 📁 1. `user-api/project.json`

```json
{
  "name": "user-api",
  "targets": {
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t ${DOCKERHUB_USERNAME}/user-api:${TAG} user-api"
      }
    },
    "docker-push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker push ${DOCKERHUB_USERNAME}/user-api:${TAG}"
      }
    }
  }
}
```

