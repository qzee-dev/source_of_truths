apiVersion: v1
kind: ConfigMap
metadata:
  name: api-gateway-config
  namespace: banking
data:
  application.yml: |
    server:
      port: 8080

    spring:
      application:
        name: api-gateway

      cloud:
        gateway:
          routes:
            - id: user-service
              uri: http://user-service
              predicates:
                - Path=/api/users/**
            - id: fund-transfer-service
              uri: http://fund-transfer-service
              predicates:
                - Path=/api/fund-transfers/**
            - id: account-service
              uri: http://account-service
              predicates:
                - Path=/accounts/**
            - id: sequence-generator
              uri: http://sequence-generator
              predicates:
                - Path=/sequence/**
            - id: transaction-service
              uri: http://transaction-service
              predicates:
                - Path=/transactions/**

      security:
        oauth2:
          client:
            provider:
              keycloak:
                token-uri: ${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/token
                authorization-uri: ${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/auth
                user-info-uri: ${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/userinfo
                jwk-set-uri: ${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs
                user-name-attribute: preferred_username

            registration:
              banking-service-client:
                provider: keycloak
                client-id: ${KEYCLOAK_CLIENT_ID}
                client-secret: ${KEYCLOAK_CLIENT_SECRET}
                authorization-grant-type: authorization_code
                redirect-uri: ${KEYCLOAK_REDIRECT_URI}
                scope: openid

          resourceserver:
            jwt:
              jwk-set-uri: ${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs
