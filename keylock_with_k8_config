📍 k8s/api-gateway/deployment.yaml
========================================================================================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-gateway
  namespace: banking
spec:
  replicas: 2
  selector:
    matchLabels:
      app: api-gateway
  template:
    metadata:
      labels:
        app: api-gateway
    spec:
      containers:
        - name: api-gateway
          image: your-repo/api-gateway:latest
          ports:
            - containerPort: 8080

          envFrom:
            - configMapRef:
                name: api-gateway-config
            - secretRef:
                name: api-gateway-keycloak-secret

          volumeMounts:
            - name: gateway-config
              mountPath: /config

      volumes:
        - name: gateway-config
          configMap:
            name: api-gateway-config
